{
  "$schema": "../gen/schemas/mobile-schema.json",
  "identifier": "android",
  "description": "Android capability: network, storage, core events",
  "platforms": ["android"],
  "windows": ["main"],
  "remote": {
    "urls": [
      "http://localhost:*",
      "http://127.0.0.1:*",
      "https://tauri.localhost"
    ]
  },
  "permissions": [
    "core:default",
    "core:event:default",
    "opener:default",
    "fs:allow-appcache-read-recursive",
    "fs:allow-appcache-write-recursive",
    "fs:allow-appdata-read-recursive",
    "fs:allow-appdata-write-recursive",
    "dialog:default",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "https://*:*" },
        { "url": "http://*:*" }
      ]
    }
  ]
}
